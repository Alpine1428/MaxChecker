# ═══════════════════════════════════════════════════════════════════
# DEBUGGER / IFEO DETECTOR (SimpleUnlocker функционал)
# Обнаруживает Image File Execution Options дебаггеры,
# которые подменяют запуск .exe файлов
# ═══════════════════════════════════════════════════════════════════

class DebuggerDetector:
    """
    Аналог SimpleUnlocker — обнаруживает IFEO дебаггеры
    (Image File Execution Options), через которые игрок может
    подменить запуск чекера или других .exe файлов.
    """

    def __init__(self, log_callback=None):
        self.log_callback = log_callback or print

    def log(self, msg: str):
        self.log_callback(msg)

    def check_ifeo(self) -> List[Dict]:
        """
        Проверяет HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion\
        Image File Execution Options на наличие Debugger ключей.
        """
        results = []
        if not WINREG_AVAILABLE:
            return results

        ifeo_path = r"SOFTWARE\Microsoft\Windows NT\CurrentVersion\Image File Execution Options"

        try:
            with winreg.OpenKey(winreg.HKEY_LOCAL_MACHINE, ifeo_path, 0,
                               winreg.KEY_READ | winreg.KEY_WOW64_64KEY) as main_key:

                num_subkeys = winreg.QueryInfoKey(main_key)[0]

                for i in range(num_subkeys):
                    try:
                        subkey_name = winreg.EnumKey(main_key, i)

                        with winreg.OpenKey(main_key, subkey_name, 0,
                                           winreg.KEY_READ | winreg.KEY_WOW64_64KEY) as sub_key:
                            try:
                                debugger_value, _ = winreg.QueryValueEx(sub_key, "Debugger")
                                if debugger_value and debugger_value.strip():
                                    # Белый список — системные дебаггеры
                                    debugger_lower = debugger_value.lower()
                                    safe_debuggers = [
                                        "vsjitdebugger", "drwtsn32", "werfault",
                                        "debugdiag", "procdump", "ntsd",
                                    ]
                                    is_safe = any(sd in debugger_lower for sd in safe_debuggers)

                                    if not is_safe:
                                        results.append({
                                            'type': 'IFEO Debugger',
                                            'exe_name': subkey_name,
                                            'debugger': debugger_value[:100],
                                            'severity': 'CRITICAL',
                                        })
                                        self.log(f"   [!!!] IFEO DEBUGGER: {subkey_name} → {debugger_value[:60]}")
                            except FileNotFoundError:
                                pass

                            # Также проверяем DisableExceptionChainValidation
                            # и другие подозрительные ключи
                            try:
                                global_flag, _ = winreg.QueryValueEx(sub_key, "GlobalFlag")
                                if global_flag and global_flag != 0:
                                    results.append({
                                        'type': 'IFEO GlobalFlag',
                                        'exe_name': subkey_name,
                                        'value': str(global_flag),
                                        'severity': 'HIGH',
                                    })
                            except FileNotFoundError:
                                pass

                    except Exception:
                        continue

        except Exception as e:
            self.log(f"   [!] IFEO check error: {str(e)[:50]}")

        return results

    def check_silent_process_exit(self) -> List[Dict]:
        """
        Проверяет SilentProcessExit — ещё один способ
        перехватить завершение процесса.
        """
        results = []
        if not WINREG_AVAILABLE:
            return results

        spe_path = r"SOFTWARE\Microsoft\Windows NT\CurrentVersion\SilentProcessExit"

        try:
            with winreg.OpenKey(winreg.HKEY_LOCAL_MACHINE, spe_path, 0,
                               winreg.KEY_READ | winreg.KEY_WOW64_64KEY) as main_key:

                num_subkeys = winreg.QueryInfoKey(main_key)[0]
                if num_subkeys > 0:
                    for i in range(num_subkeys):
                        try:
                            subkey_name = winreg.EnumKey(main_key, i)
                            results.append({
                                'type': 'SilentProcessExit',
                                'exe_name': subkey_name,
                                'severity': 'HIGH',
                            })
                            self.log(f"   [!] SilentProcessExit: {subkey_name}")
                        except:
                            continue
        except FileNotFoundError:
            pass
        except Exception as e:
            self.log(f"   [!] SPE check error: {str(e)[:50]}")

        return results

    def check_all(self) -> List[Dict]:
        """Запускает все проверки дебаггеров"""
        self.log("   [*] Checking for debuggers/IFEO...")
        results = []
        results.extend(self.check_ifeo())
        results.extend(self.check_silent_process_exit())

        if results:
            self.log(f"   [!!!] Found {len(results)} debugger restrictions!")
        else:
            self.log(f"   [+] No debugger restrictions found")

        return results


