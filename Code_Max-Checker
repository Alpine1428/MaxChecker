    def find_minecraft(self):
        paths = find_minecraft_folders()
        if paths:
            self.minecraft_path = paths[0]
            self.path_label.config(text=f"📂 {self.minecraft_path}")
        else:
            self.path_label.config(text="⚠️ Minecraft не найден!")

    def log(self, msg: str):
        try:
            m = re.search(r"\[(\d+)\s*/\s*(\d+)\]", msg)
            if m:
                pct = max(0, min(100, int(int(m.group(1)) / int(m.group(2)) * 100)))
                self.progress['value'] = pct
                self.progress_label.config(text=f"{pct}%")
        except:
            pass
        
        try:
            print(f"[{datetime.datetime.now().strftime('%H:%M:%S')}] {msg}")
        except:
            pass
        self.root.update()

    def show_completion_banner(self):
        """Показывает БОЛЬШОЙ баннер о завершении сканирования"""
        
        # Закрываем предыдущее окно если есть
        if self.completion_window:
            try:
                self.completion_window.destroy()
            except:
                pass
        
        # Создаём новое окно-баннер
        self.completion_window = tk.Toplevel(self.root)
        self.completion_window.title("Сканирование завершено")
        
        # Размеры и позиция (по центру экрана)
        banner_w, banner_h = 450, 280
        screen_w = self.root.winfo_screenwidth()
        screen_h = self.root.winfo_screenheight()
        pos_x = (screen_w // 2) - (banner_w // 2)
        pos_y = (screen_h // 2) - (banner_h // 2)
        
        self.completion_window.geometry(f"{banner_w}x{banner_h}+{pos_x}+{pos_y}")
        self.completion_window.resizable(False, False)
        self.completion_window.configure(bg="#0a0f1a")
        
        # Делаем окно поверх всех
        self.completion_window.attributes('-topmost', True)
        self.completion_window.focus_force()
        
        # Рамка
        border_frame = tk.Frame(self.completion_window, bg=self.accent_success, bd=0)
        border_frame.pack(fill="both", expand=True, padx=3, pady=3)
        
        inner_frame = tk.Frame(border_frame, bg="#0a0f1a")
        inner_frame.pack(fill="both", expand=True, padx=2, pady=2)
        
        # Большая иконка
        icon_label = tk.Label(
            inner_frame,
            text="✅",
            font=("Segoe UI Emoji", 48),
            fg=self.accent_success,
            bg="#0a0f1a"
        )
        icon_label.pack(pady=(25, 10))
        
        # Заголовок
        title_label = tk.Label(
            inner_frame,
            text="СКАНИРОВАНИЕ ЗАВЕРШЕНО",
            font=("Segoe UI", 18, "bold"),
            fg=self.accent_success,
            bg="#0a0f1a"
        )
        title_label.pack(pady=(0, 5))
        
        # Подзаголовок
        subtitle_label = tk.Label(
            inner_frame,
            text="Результаты отправлены модератору",
            font=("Segoe UI", 11),
            fg=self.text_muted,
            bg="#0a0f1a"
        )
        subtitle_label.pack(pady=(0, 20))
        
        # Кнопка закрытия
        close_btn = tk.Button(
            inner_frame,
            text="ЗАКРЫТЬ",
            font=("Segoe UI", 12, "bold"),
            bg=self.accent_success,
            fg="white",
            activebackground="#059669",
            relief="flat",
            cursor="hand2",
            padx=40,
            pady=8,
            command=self.completion_window.destroy
        )
        close_btn.pack(pady=(0, 20))
        
        # Анимация мигания рамки
        self.blink_count = 0
        self.blink_border(border_frame)
        
        # Звуковое уведомление
        try:
            import winsound
            # Тройной звук для привлечения внимания
            for _ in range(2):
                winsound.MessageBeep(winsound.MB_ICONASTERISK)
                time.sleep(0.15)
        except:
            pass
        
        # Автозакрытие через 30 секунд
        self.completion_window.after(30000, lambda: self.completion_window.destroy() if self.completion_window else None)
    
    def blink_border(self, border_frame):
        """Мигающая анимация рамки"""
        if self.blink_count < 8:
            colors = [self.accent_success, "#0a0f1a"]
            current = colors[self.blink_count % 2]
            try:
                border_frame.config(bg=current)
            except:
                return
            self.blink_count += 1
            self.root.after(250, lambda: self.blink_border(border_frame))
        else:
            try:
                border_frame.config(bg=self.accent_success)
            except:
                pass

    def update_main_window_complete(self):
        """Обновляет главное окно при завершении"""
        # Зелёная рамка
        self.outer_card.config(highlightbackground=self.accent_success, highlightthickness=3)
        
        # Зелёный индикатор
        self.indicator.itemconfig(self.indicator_circle, fill=self.accent_success, outline=self.accent_success)
        
        # Зелёный акцент
        self.accent_bar.config(bg=self.accent_success)
        
        # Зелёный прогресс
        self.progress.configure(style="Complete.Horizontal.TProgressbar")
        self.progress['value'] = 100
        self.progress_label.config(text="100%", fg=self.accent_success)
        
        # Статус
        self.status.config(text="✅ Сканирование завершено!", fg=self.accent_success)

    def reset_ui(self):
        """Сбрасывает UI"""
        self.outer_card.config(highlightbackground=self.border_color, highlightthickness=2)
        self.indicator.itemconfig(self.indicator_circle, fill=self.accent_secondary, outline=self.accent_primary)
        self.accent_bar.config(bg=self.accent_primary)
        self.progress.configure(style="Neon.Horizontal.TProgressbar")
        self.progress['value'] = 0
        self.progress_label.config(text="0%", fg=self.text_muted)
        self.status.config(text="⏳ Ожидание...", fg=self.text_muted)

    def start_scan(self):
        if self.scanning:
            return

        self.reset_ui()

        raw_code = self.code_entry.get()
        try:
            code = normalize_moderator_code(raw_code)
        except:
            code = raw_code.strip()

        self.code_entry.delete(0, tk.END)
        self.code_entry.insert(0, code)

        if not code:
            messagebox.showwarning("Ошибка", "Введите код!")
            return
        if not self.minecraft_path:
            messagebox.showerror("Ошибка", "Minecraft не найден!")
            return

        self.scanning = True
        self.scan_btn.config(state="disabled", text="🔄 СКАНИРОВАНИЕ...", bg="#4B5563")
        self.code_entry.config(state="disabled")

        threading.Thread(target=self.run_process, args=(code,), daemon=True).start()

    def run_process(self, code: str):
        if PYTHONCOM_AVAILABLE:
            try:
                pythoncom.CoInitialize()
            except:
                pass
        
        try:
            self.log("🔐 Проверка кода...")
            self.status.config(text="🔐 Проверка кода...", fg=self.accent_primary)
            
            auth = TelegramDirect()
            ok, msg = auth.verify_code(code)
            if not ok:
                self.status.config(text=f"❌ {msg}", fg="#ef4444")
                self.finish_scan()
                return

            self.status.config(text="🔍 Сканирование системы...", fg=self.accent_primary)

            checker = HolyChecker(self.minecraft_path, self.log)
            result = checker.run_all_checks()

            self.status.config(text="📤 Отправка результатов...", fg=self.accent_primary)
            auth.submit_result(result)

            # Обновляем главное окно
            self.update_main_window_complete()
            
            # Показываем баннер
            self.root.after(100, self.show_completion_banner)

        except Exception as e:
            self.log(f"❌ Ошибка: {e}")
            self.status.config(text="❌ Произошла ошибка", fg="#ef4444")
        finally:
            if PYTHONCOM_AVAILABLE:
                try:
                    pythoncom.CoUninitialize()
                except:
                    pass
            self.finish_scan()

    def finish_scan(self):
        self.scanning = False
        self.scan_btn.config(state="normal", text="🔍 НАЧАТЬ ПРОВЕРКУ", bg=self.accent_primary)
        self.code_entry.config(state="normal")

    def run(self):
        self.root.mainloop()

