class DLLPackerDetector:
    """
    Аналог DIE (Detect It Easy) — проверяет DLL/EXE файлы
    на наличие пакеров (UPX, VMProtect, Themida, etc.)
    по сигнатурам в PE-заголовках и секциях.
    """

    # Известные пакеры/протекторы и их сигнатуры в секциях
    PACKER_SIGNATURES = {
        # Секции
        b"UPX0":            "UPX (packer)",
        b"UPX1":            "UPX (packer)",
        b"UPX2":            "UPX (packer)",
        b".vmp0":           "VMProtect",
        b".vmp1":           "VMProtect",
        b".vmp2":           "VMProtect",
        b"VProtect":        "VMProtect",
        b".themida":        "Themida",
        b"Themida":         "Themida",
        b".enigma1":        "Enigma Protector",
        b".enigma2":        "Enigma Protector",
        b"Enigma":          "Enigma Protector",
        b".aspack":         "ASPack",
        b"ASPack":          "ASPack",
        b".adata":          "ASPack",
        b".nsp0":           "NsPack",
        b".nsp1":           "NsPack",
        b"nsp":             "NsPack",
        b".mpress1":        "MPress",
        b".mpress2":        "MPress",
        b"MPRESS1":         "MPress",
        b"MPRESS2":         "MPress",
        b"PECompact":       "PECompact",
        b".petite":         "Petite",
        b"Petite":          "Petite",
        b".yP":             "Y0da Protector",
        b".pec":            "PECrypt",
        b"ExeStealth":      "EXE Stealth",
        b"pelock":          "PELock",
        b".sforce":         "StarForce",
        b"securom":         "SecuROM",
        b"denuvo":          "Denuvo",
        b".packed":         "Generic Packer",
        b"Confuser":        "ConfuserEx (.NET)",
        b"ConfuserEx":      "ConfuserEx (.NET)",
        b"Babel":           "Babel Obfuscator (.NET)",
        b"Dotfuscator":     "Dotfuscator (.NET)",
        b"SmartAssembly":   "SmartAssembly (.NET)",
        b"Agile.NET":       "Agile.NET (.NET)",
        b"Eazfuscator":     "Eazfuscator.NET",
    }

    # Строки в импортах/экспортах, указывающие на защиту
    PROTECTION_STRINGS = [
        b"VirtualProtect",      # часто используется пакерами
        b"IsDebuggerPresent",   # антиотладка
        b"CheckRemoteDebuggerPresent",
        b"NtQueryInformationProcess",
        b"OutputDebugString",
        b"SetUnhandledExceptionFilter",
    ]

    def __init__(self, log_callback=None):
        self.log_callback = log_callback or print

    def log(self, msg: str):
        self.log_callback(msg)

    def check_pe_headers(self, filepath: str) -> Dict:
        """
        Анализирует PE-заголовки файла на наличие пакеров.
        Не требует внешних библиотек — парсит вручную.
        """
        result = {
            'path': filepath,
            'name': os.path.basename(filepath),
            'packers_found': [],
            'suspicious_sections': [],
            'anti_debug': [],
            'is_packed': False,
            'severity': 'CLEAN',
        }

        try:
            with open(filepath, 'rb') as f:
                data = f.read(min(os.path.getsize(filepath), 2 * 1024 * 1024))

            if len(data) < 64:
                return result

            # Проверяем MZ заголовок
            if data[:2] != b'MZ':
                return result

            # Получаем смещение PE заголовка
            pe_offset = struct.unpack_from('<I', data, 0x3C)[0]
            if pe_offset + 4 > len(data) or data[pe_offset:pe_offset + 4] != b'PE\x00\x00':
                return result

            # Парсим COFF header
            coff_offset = pe_offset + 4
            num_sections = struct.unpack_from('<H', data, coff_offset + 2)[0]

            # Парсим Optional Header
            optional_header_offset = coff_offset + 20
            optional_header_size = struct.unpack_from('<H', data, coff_offset + 16)[0]

            # Секции начинаются после optional header
            sections_offset = optional_header_offset + optional_header_size

            # Проверяем каждую секцию
            for i in range(min(num_sections, 96)):
                section_offset = sections_offset + i * 40
                if section_offset + 40 > len(data):
                    break

                section_name = data[section_offset:section_offset + 8].rstrip(b'\x00')

                # Проверяем имя секции на известные пакеры
                for sig, packer_name in self.PACKER_SIGNATURES.items():
                    if sig in section_name or section_name.startswith(sig):
                        result['packers_found'].append(packer_name)
                        result['suspicious_sections'].append(section_name.decode('ascii', errors='ignore'))
                        self.log(f"   [!!!] PACKER: {packer_name} in section {section_name.decode(errors='ignore')}")

                # Проверяем характеристики секции
                characteristics = struct.unpack_from('<I', data, section_offset + 36)[0]
                # RWX секция — подозрительно
                IMAGE_SCN_MEM_EXECUTE = 0x20000000
                IMAGE_SCN_MEM_READ = 0x40000000
                IMAGE_SCN_MEM_WRITE = 0x80000000
                if (characteristics & IMAGE_SCN_MEM_EXECUTE and
                    characteristics & IMAGE_SCN_MEM_READ and
                    characteristics & IMAGE_SCN_MEM_WRITE):
                    sec_name = section_name.decode('ascii', errors='ignore')
                    if sec_name not in ['.text', '.code']:
                        result['suspicious_sections'].append(f"RWX: {sec_name}")

            # Ищем строки пакеров по всему файлу (первые 500KB)
            search_data = data[:min(len(data), 512 * 1024)]
            for sig, packer_name in self.PACKER_SIGNATURES.items():
                if sig in search_data and packer_name not in result['packers_found']:
                    result['packers_found'].append(packer_name)
                    self.log(f"   [!!!] PACKER STRING: {packer_name}")

            # Проверяем антиотладочные функции
            for anti_debug in self.PROTECTION_STRINGS:
                if anti_debug in data:
                    func_name = anti_debug.decode('ascii', errors='ignore')
                    # IsDebuggerPresent часто бывает в нормальных файлах,
                    # поэтому помечаем только при наличии других признаков
                    result['anti_debug'].append(func_name)

            # Проверяем энтропию (высокая = упакован)
            entropy = self._calculate_entropy(data[:min(len(data), 256 * 1024)])
            if entropy > 7.2:
                result['packers_found'].append(f"High entropy ({entropy:.2f})")
                self.log(f"   [!] High entropy: {entropy:.2f}")

            # Итого
            if result['packers_found']:
                result['is_packed'] = True
                result['severity'] = 'CRITICAL'
            elif len(result['anti_debug']) >= 3:
                result['severity'] = 'HIGH'
            elif result['suspicious_sections']:
                result['severity'] = 'MEDIUM'

        except Exception as e:
            self.log(f"   [!] PE analysis error ({os.path.basename(filepath)}): {str(e)[:40]}")

        return result

    def _calculate_entropy(self, data: bytes) -> float:
        """Вычисляет энтропию Шеннона"""
        if not data:
            return 0.0
        counter = Counter(data)
        length = len(data)
        entropy = 0.0
        for count in counter.values():
            if count > 0:
                probability = count / length
                entropy -= probability * math.log2(probability)
        return entropy

    def scan_unsigned_dlls_from_csrss(self, csrss_paths: List[Dict]) -> List[Dict]:
        """
        Сканирует DLL найденные в CSRSS на наличие пакеров.
        Это объединяет функционал PathParser + DIE из мануала.
        """
        results = []

        for item in csrss_paths:
            path = item.get('path', '')
            if not path or not os.path.exists(path):
                continue

            if not path.lower().endswith(('.dll', '.exe')):
                continue

            # Проверяем только неподписанные и не из безопасных путей
            if is_safe_path(path) or is_safe_dll(os.path.basename(path)):
                continue

            analysis = self.check_pe_headers(path)
            if analysis['is_packed'] or analysis['severity'] != 'CLEAN':
                results.append(analysis)

        return results

    def scan_bam_unsigned(self, bam_results: List[Dict]) -> List[Dict]:
        """Сканирует BAM unsigned файлы на пакеры"""
        results = []

        for item in bam_results:
            path = item.get('path', '')
            if not path or not os.path.exists(path):
                continue

            analysis = self.check_pe_headers(path)
            if analysis['is_packed'] or analysis['severity'] != 'CLEAN':
                results.append(analysis)

        return results


