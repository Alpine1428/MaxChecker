# APPCOMPAT FLAGS DETECTOR
# Проверяет очистку AppCompatFlags в реестре
# ═══════════════════════════════════════════════════════════════════

class AppCompatFlagsDetector:
    """
    Проверяет очистку AppCompatFlags — раздел реестра, который
    хранит информацию о запуске программ.
    Из мануала: ROOT\Software\Microsoft\Windows NT\CurrentVersion\AppCompatFlags
    """

    def __init__(self, log_callback=None):
        self.log_callback = log_callback or print

    def log(self, msg: str):
        self.log_callback(msg)

    def check_appcompat_cleaning(self) -> List[Dict]:
        results = []
        if not WINREG_AVAILABLE:
            return results

        # Проверяем AppCompatFlags\Compatibility Assistant\Store
        paths_to_check = [
            (r"Software\Microsoft\Windows NT\CurrentVersion\AppCompatFlags\Compatibility Assistant\Store",
             "AppCompatFlags Store", winreg.HKEY_CURRENT_USER),
            (r"Software\Microsoft\Windows NT\CurrentVersion\AppCompatFlags\Layers",
             "AppCompatFlags Layers", winreg.HKEY_CURRENT_USER),
        ]

        for reg_path, name, hive in paths_to_check:
            try:
                with winreg.OpenKey(hive, reg_path, 0,
                                   winreg.KEY_READ | winreg.KEY_WOW64_64KEY) as key:
                    num_values = winreg.QueryInfoKey(key)[1]

                    if num_values == 0:
                        results.append({
                            'type': 'AppCompatFlags Cleaned',
                            'key': name,
                            'detail': f'Empty ({num_values} values)',
                            'severity': 'CRITICAL',
                        })
                        self.log(f"   [!!!] CLEANED: {name} (0 values)")
                    elif num_values < 5:
                        results.append({
                            'type': 'AppCompatFlags Suspicious',
                            'key': name,
                            'detail': f'Very few values ({num_values})',
                            'severity': 'HIGH',
                        })
                        self.log(f"   [!] SUSPICIOUS: {name} ({num_values} values)")

            except FileNotFoundError:
                results.append({
                    'type': 'AppCompatFlags Missing',
                    'key': name,
                    'detail': 'Key does not exist',
                    'severity': 'CRITICAL',
                })
                self.log(f"   [!!!] MISSING: {name}")
            except Exception as e:
                self.log(f"   [!] AppCompat error: {str(e)[:40]}")

        # Проверяем FeatureUsage
        feature_usage_path = r"Software\Microsoft\Windows\CurrentVersion\Explorer\FeatureUsage"
        try:
            with winreg.OpenKey(winreg.HKEY_CURRENT_USER, feature_usage_path, 0,
                               winreg.KEY_READ | winreg.KEY_WOW64_64KEY) as key:
                num_subkeys = winreg.QueryInfoKey(key)[0]
                if num_subkeys == 0:
                    results.append({
                        'type': 'FeatureUsage Cleaned',
                        'key': 'Explorer\\FeatureUsage',
                        'detail': 'No subkeys',
                        'severity': 'HIGH',
                    })
                    self.log(f"   [!] CLEANED: FeatureUsage")
        except FileNotFoundError:
            results.append({
                'type': 'FeatureUsage Missing',
                'key': 'Explorer\\FeatureUsage',
                'detail': 'Key does not exist',
                'severity': 'CRITICAL',
            })
        except:
            pass

        return results


