            ("HitboxExpand", "Cheat: HitboxExpand"),
        ]

        for key, desc in cheat_strings:
            self._add_pattern(key, desc, "cheat_module_name",
                [key.encode('utf-8')], require_all=False, severity="CRITICAL", is_module_name=True)

    def _add_pattern(self, setting_key, name, category, patterns,
                     require_all=False, severity="HIGH", extra_context=None,
                     is_module_name=False):
        if setting_key not in JAR_SCAN_SETTINGS:
            return
        if not JAR_SCAN_SETTINGS[setting_key]:
            return
        self.active_patterns.append({
            'setting_key': setting_key, 'name': name, 'category': category,
            'patterns': patterns, 'require_all': require_all,
            'severity': severity, 'extra_context': extra_context or [],
            'is_module_name': is_module_name,
        })

    def _is_whitelisted(self, name: str) -> bool:
        name_lower = name.lower().replace(' ', '').replace('-', '').replace('_', '')
        for safe in JAR_MOD_WHITELIST:
            safe_norm = safe.lower().replace(' ', '').replace('-', '').replace('_', '')
            if safe_norm in name_lower or name_lower in safe_norm:
                return True
        return False

    def _is_safe_class_path(self, class_path: str) -> bool:
        safe_packages = [
            "net/minecraft/", "com/mojang/", "org/lwjgl/",
            "com/google/", "org/apache/", "io/netty/",
            "optifine/", "me/jellysquid/", "net/fabricmc/",
            "net/minecraftforge/", "com/mumfrey/liteloader/",
            "net/labymod/", "com/labymod/",
            "me/shedaniel/", "dev/emi/", "mezz/jei/",
            "journeymap/", "xaero/", "com/mamiyaotaru/voxelmap/",
            "com/replaymod/", "fi/dy/masa/",
            "net/optifine/", "org/spongepowered/asm/",
        ]
        class_lower = class_path.lower()
        return any(class_lower.startswith(safe) for safe in safe_packages)

    def _get_mod_info(self, jar: zipfile.ZipFile) -> Dict[str, str]:
        info = {'name': '', 'id': '', 'type': 'unknown'}

        try:
            if 'fabric.mod.json' in jar.namelist():
                data = json.loads(jar.read('fabric.mod.json').decode('utf-8', errors='ignore'))
                info['name'] = data.get('name', '')
                info['id'] = data.get('id', '')
                info['type'] = 'fabric'
                return info
        except: pass

        try:
            if 'META-INF/MANIFEST.MF' in jar.namelist():
                manifest = jar.read('META-INF/MANIFEST.MF').decode('utf-8', errors='ignore')
                for line in manifest.splitlines():
                    if line.startswith('Implementation-Title:'):
                        info['name'] = line.split(':', 1)[1].strip()
                        info['type'] = 'forge'
                    elif line.startswith('Specification-Title:'):
                        if not info['name']:
                            info['name'] = line.split(':', 1)[1].strip()
                        info['type'] = 'forge'
                if info['name']: return info
        except: pass

        try:
            if 'mcmod.info' in jar.namelist():
                raw = jar.read('mcmod.info').decode('utf-8', errors='ignore')
                data = json.loads(raw)
                if isinstance(data, list) and len(data) > 0:
                    info['name'] = data[0].get('name', '')
                    info['id'] = data[0].get('modid', '')
                    info['type'] = 'forge_legacy'
                    return info
        except: pass

        try:
            if 'META-INF/mods.toml' in jar.namelist():
                toml_content = jar.read('META-INF/mods.toml').decode('utf-8', errors='ignore')
                for line in toml_content.splitlines():
                    line = line.strip()
                    if line.startswith('modId'):
                        info['id'] = line.split('=', 1)[1].strip().strip('"').strip("'")
                        info['type'] = 'forge_modern'
                    elif line.startswith('displayName'):
                        info['name'] = line.split('=', 1)[1].strip().strip('"').strip("'")
                if info['name'] or info['id']: return info
        except: pass

        return info

    def _check_mod_name_banned(self, mod_info: Dict) -> List[Dict]:
        findings = []
        name = mod_info.get('name', '').lower().strip()
        mod_id = mod_info.get('id', '').lower().strip()
        mod_type = mod_info.get('type', 'unknown')

        for banned in BANNED_MOD_NAMES:
            banned_lower = banned.lower()
            if name and banned_lower in name.replace(' ', '').replace('-', '').replace('_', ''):
                findings.append({
                    'detection': f'Запрещённое имя мода: "{mod_info["name"]}"',
                    'category': 'banned_mod_name', 'matched': banned,
                    'source': f'{mod_type}: name="{mod_info["name"]}"', 'severity': 'CRITICAL',
                })
            if mod_id and banned_lower in mod_id.replace(' ', '').replace('-', '').replace('_', ''):
                findings.append({
                    'detection': f'Запрещённый ID мода: "{mod_info["id"]}"',
                    'category': 'banned_mod_id', 'matched': banned,
                    'source': f'{mod_type}: id="{mod_info["id"]}"', 'severity': 'CRITICAL',
                })
        return findings

    def _check_class_names_banned(self, jar: zipfile.ZipFile) -> List[Dict]:
        findings = []
        found_banned = set()
        for entry_name in jar.namelist():
            if not entry_name.endswith('.class'): continue
            if self._is_safe_class_path(entry_name): continue
            class_path_lower = entry_name.lower().replace('/', '.').replace('\\', '.')
            for banned in BANNED_MOD_NAMES:
                if banned.lower() in class_path_lower:
                    key = f"{banned}_{entry_name}"
                    if key not in found_banned:
                        found_banned.add(key)
                        findings.append({
                            'detection': f'Запрещённый модуль: {banned}',
                            'category': 'banned_class_name', 'matched': banned,
                            'source': f'class: {entry_name}', 'severity': 'CRITICAL',
                        })
        return findings[:20]

    def _scan_class_content(self, jar: zipfile.ZipFile) -> List[Dict]:
        findings = []
        found_patterns = set()
        for entry_name in jar.namelist():
            if not entry_name.endswith('.class'): continue
            if self._is_safe_class_path(entry_name): continue
            try: content = jar.read(entry_name)
            except: continue
            if len(content) < 50: continue
            for pattern_def in self.active_patterns:
                if pattern_def.get('is_module_name'):
                    self._check_module_name(content, entry_name, pattern_def, findings, found_patterns)
                else:
                    self._check_pattern(content, entry_name, pattern_def, findings, found_patterns)
        return findings

    def _check_pattern(self, content, class_name, pattern_def, findings, found_patterns):
        patterns = pattern_def['patterns']
        content_lower = content.lower()
        if pattern_def['require_all']:
            if not all(p.lower() in content_lower for p in patterns): return
        else:
            if not any(p.lower() in content_lower for p in patterns): return
            if pattern_def.get('extra_context'):
                if not any(ctx.lower() in content_lower for ctx in pattern_def['extra_context']): return

        dedup_key = f"{pattern_def['name']}|{class_name}"
        if dedup_key in found_patterns: return
        found_patterns.add(dedup_key)

        matched = [p.decode('utf-8', errors='ignore') for p in patterns if p.lower() in content_lower]
        findings.append({
            'detection': pattern_def['name'], 'category': pattern_def['category'],
            'matched': ', '.join(matched), 'source': f'class: {class_name}',
            'severity': pattern_def['severity'], 'setting_key': pattern_def['setting_key'],
        })

    def _check_module_name(self, content, class_name, pattern_def, findings, found_patterns):
        keyword = pattern_def['patterns'][0]
        keyword_str = keyword.decode('utf-8', errors='ignore')
        if len(keyword_str) <= 3: return

        false_positive_words = {
            "Speed": [b"SpeedRun", b"SpeedTest", b"SpeedLimit", b"WindSpeed",
                      b"MoveSpeed", b"SpeedBoost", b"speed_", b"maxSpeed",
                      b"walkSpeed", b"swimSpeed", b"flySpeed", b"movementSpeed"],
            "Timer": [b"TimerTask", b"Timer.schedule", b"GameTimer",
                      b"java/util/Timer", b"TimerCallback", b"worldTimer", b"renderTimer"],
            "Reach": [b"ReachAround", b"ReachDistance", b"reach_distance",
                      b"reachable", b"unreachable"],
            "Phase": [b"PhaseType", b"Phase.java", b"tickPhase",
                      b"moonPhase", b"phase_", b"buildPhase"],
            "Blink": [b"BlinkAnimation", b"blinkTimer", b"eyeBlink"],
            "ESP":   [b"RESP", b"espresso", b"RESPONSE", b"escape", b"Despawn"],
            "Flight": [b"FlightRecorder", b"FlightEvent", b"flightPath",
                       b"java/lang/management"],
        }

        content_lower = content.lower()
        keyword_lower = keyword.lower()
        if keyword_lower not in content_lower: return

        if keyword_str in false_positive_words:
            for fp in false_positive_words[keyword_str]:
                if fp.lower() in content_lower: return
            cheat_context = [b"toggle", b"enable", b"disable", b"module", b"hack",
                             b"cheat", b"activate", b"config", b"onEnable", b"onDisable", b"isEnabled"]
            if not any(cw.lower() in content_lower for cw in cheat_context): return

        dedup_key = f"module_{keyword_str}|{class_name}"
        if dedup_key in found_patterns: return
        found_patterns.add(dedup_key)

        findings.append({
            'detection': f'Чит-модуль: {keyword_str}', 'category': 'cheat_module_name',
            'matched': keyword_str, 'source': f'class: {class_name}',
            'severity': 'CRITICAL', 'setting_key': pattern_def['setting_key'],
        })

    def _check_obfuscation(self, jar: zipfile.ZipFile) -> bool:
        class_count, obfuscated_count = 0, 0
        for name in jar.namelist():
            if not name.endswith('.class'): continue
            if self._is_safe_class_path(name): continue
            class_count += 1
            cn = os.path.basename(name).replace('.class', '')
            if len(cn) <= 2 or re.match(r'^[a-zA-Z]{1,3}$', cn):
                obfuscated_count += 1
        return class_count > 10 and obfuscated_count / class_count > 0.6

    def _check_mod_date(self, jar_path: str) -> Optional[str]:
        """Проверяет дату модификации — из мануала: бан если <14 дней"""
        file_date = get_file_date(jar_path)
        if file_date and is_within_14_days(file_date):
            return file_date.strftime('%Y-%m-%d %H:%M:%S')
        return None

    def analyze_jar(self, jar_path: str) -> Optional[Dict]:
        filename = os.path.basename(jar_path)
        if self._is_whitelisted(filename): return None

        try:
            with zipfile.ZipFile(jar_path, 'r') as jar:
                mod_info = self._get_mod_info(jar)
                if mod_info['name'] and self._is_whitelisted(mod_info['name']): return None
                if mod_info['id'] and self._is_whitelisted(mod_info['id']): return None

                all_findings = []
                all_findings.extend(self._check_mod_name_banned(mod_info))
                all_findings.extend(self._check_class_names_banned(jar))
                all_findings.extend(self._scan_class_content(jar))

                is_obfuscated = self._check_obfuscation(jar)
                mod_date = self._check_mod_date(jar_path)

                if not all_findings and not is_obfuscated: return None

                severity_order = {'CLEAN': 0, 'LOW': 1, 'MEDIUM': 2, 'HIGH': 3, 'CRITICAL': 4}
                max_severity = 'CLEAN'
                for f in all_findings:
                    if severity_order.get(f['severity'], 0) > severity_order.get(max_severity, 0):
                        max_severity = f['severity']
                if is_obfuscated and max_severity == 'CLEAN':
                    max_severity = 'MEDIUM'

                return {
                    'name': filename, 'path': jar_path,
                    'mod_name': mod_info.get('name', ''), 'mod_id': mod_info.get('id', ''),
                    'mod_type': mod_info.get('type', 'unknown'),
                    'findings': all_findings, 'is_obfuscated': is_obfuscated,
                    'severity': max_severity,
                    'mod_date': mod_date,
                    'file_size': get_file_size(jar_path),
                }
        except zipfile.BadZipFile: return None
        except Exception as e:
            self.log(f"   [!] Error: {filename}: {str(e)[:50]}")
            return None

    def scan_mods_folder(self, minecraft_path: str) -> List[Dict]:
        results = []
        scan_paths = [
            (os.path.join(minecraft_path, 'mods'), 'mods'),
            (os.path.join(minecraft_path, 'labymod-neo', 'addons'), 'labymod-neo/addons'),
            (os.path.join(minecraft_path, 'LabyMod', 'addons-1.16'), 'LabyMod/addons-1.16'),
        ]

        versions_path = os.path.join(minecraft_path, 'versions')
        if os.path.exists(versions_path):
            try:
                for ver_dir in os.listdir(versions_path):
                    ver_mods = os.path.join(versions_path, ver_dir, 'mods')
                    if os.path.exists(ver_mods):
                        scan_paths.append((ver_mods, f'versions/{ver_dir}/mods'))
            except: pass

        total_scanned, total_found = 0, 0

        for folder_path, folder_label in scan_paths:
            if not os.path.exists(folder_path): continue
            self.log(f"   [*] Scanning: {folder_label}")
            try:
                jar_files = [f for f in os.listdir(folder_path)
                             if f.lower().endswith('.jar') and os.path.isfile(os.path.join(folder_path, f))]
            except: continue

            self.log(f"   [*] Found {len(jar_files)} JAR files in {folder_label}")

            for jar_file in jar_files:
                jar_path = os.path.join(folder_path, jar_file)
                total_scanned += 1
                analysis = self.analyze_jar(jar_path)
                if analysis and analysis['severity'] != 'CLEAN':
                    analysis['folder'] = folder_label
                    results.append(analysis)
                    total_found += 1
                    sev_icon = "🚨" if analysis['severity'] == 'CRITICAL' else "⚠️"
                    self.log(f"   {sev_icon} [{analysis['severity']}] {jar_file}")
                    for finding in analysis.get('findings', [])[:3]:
                        self.log(f"       → {finding['detection']}")

        self.log(f"   [+] JAR scan: {total_scanned} scanned, {total_found} suspicious")
        return results
	
class JumpListAnalyzer:
    def __init__(self, log_callback=None):
        self.log_callback = log_callback or print
    def log(self, msg: str): self.log_callback(msg)
    def analyze_jumplists(self) -> List[Dict]:
        results = []
        appdata = os.environ.get('APPDATA', '')
        auto_dest = os.path.join(appdata, r'Microsoft\Windows\Recent\AutomaticDestinations')
        custom_dest = os.path.join(appdata, r'Microsoft\Windows\Recent\CustomDestinations')
        path_pattern = re.compile(rb'[A-Za-z]:\\[^\x00]{5,200}\.(?:exe|dll|jar|zip|rar)', re.IGNORECASE)
        all_paths = []
        for dest_path in [auto_dest, custom_dest]:
            if os.path.exists(dest_path):
                try:
                    for file in os.listdir(dest_path):
                        try:
                            with open(os.path.join(dest_path, file), 'rb') as f:
                                for p in path_pattern.findall(f.read()):
                                    try:
                                        path = p.decode('utf-8', errors='ignore')
                                        if path not in all_paths: all_paths.append(path)
                                    except: pass
                        except: pass
                except: pass
        for path in all_paths:
            path_lower = path.lower()
            filename = os.path.basename(path_lower)
            if is_safe_path(path_lower) or is_safe_mod(filename): continue
            if is_cheat_name(filename):
                results.append({'type': 'JumpList', 'path': path, 'filename': filename, 'exists': os.path.exists(path), 'severity': 'CRITICAL'})
                self.log(f"   [!!!] JumpList: {filename}")
            elif filename.endswith('.dll') and os.path.exists(path):
                banned = is_banned_dll_size(get_file_size(path))
                if banned: results.append({'type': 'JumpList DLL', 'path': path, 'filename': filename, 'reason': banned, 'severity': 'CRITICAL'})
        return results[:30]

