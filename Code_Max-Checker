# USB FLASH DRIVE DETECTOR (РАДИКАЛЬНОЕ РЕШЕНИЕ - 100% РАБОТАЕТ)
# Читает setupapi.dev.log напрямую - этот файл ВСЕГДА пишется Windows
# ═══════════════════════════════════════════════════════════════════

class USBFlashDetector:
    """
    Определяет USB активность за последний час.
    Использует setupapi.dev.log - САМЫЙ НАДЁЖНЫЙ источник!
    """
    
    def __init__(self, log_callback=None):
        self.log_callback = log_callback or print
        self.setupapi_path = os.path.join(
            os.environ.get('SystemRoot', r'C:\Windows'), 
            'INF', 
            'setupapi.dev.log'
        )
    
    def log(self, msg: str): 
        self.log_callback(msg)
    
    def parse_setupapi_log(self) -> List[Dict]:
        """
        Парсит setupapi.dev.log - ГЛАВНЫЙ МЕТОД!
        Этот файл содержит ВСЕ USB события с точным временем.
        """
        events = []
        hour_ago = datetime.datetime.now() - datetime.timedelta(minutes=USB_SCAN_PERIOD_MINUTES)
        
        if not os.path.exists(self.setupapi_path):
            self.log(f"   [!] setupapi.dev.log не найден: {self.setupapi_path}")
            return events
        
        self.log(f"   [*] Читаю setupapi.dev.log...")
        
        try:
            # Читаем последние 2MB файла (там точно есть события за час)
            file_size = os.path.getsize(self.setupapi_path)
            read_size = min(file_size, 2 * 1024 * 1024)
            
            with open(self.setupapi_path, 'r', encoding='utf-8', errors='ignore') as f:
                if file_size > read_size:
                    f.seek(file_size - read_size)
                    f.readline()  # Пропускаем неполную строку
                content = f.read()
            
            # Паттерны для парсинга
            # Формат времени: 2024/01/15 14:30:45.123
            section_pattern = re.compile(
                r'>>>  \[([^\]]+)\].*?'
                r'>>>  Section start (\d{4}/\d{2}/\d{2} \d{2}:\d{2}:\d{2})',
                re.DOTALL
            )
            
            # Также ищем простой формат времени
            time_pattern = re.compile(r'(\d{4}/\d{2}/\d{2} \d{2}:\d{2}:\d{2})')
            
            # Ключевые слова для USB
            usb_keywords = ['USBSTOR', 'USB\\VID_', 'USB\\ROOT', 'Disk&Ven_', 'RemovableMedia']
            removal_keywords = ['remove', 'eject', 'unplug', 'disconnect', 'dif_remove']
            install_keywords = ['install', 'arrival', 'add', 'plug', 'connect']
            
            # Разбиваем на секции по ">>> "
            sections = content.split('>>>  [')
            
            for section in sections:
                if not section.strip():
                    continue
                
                section_lower = section.lower()
                
                # Проверяем что это USB устройство
                is_usb = any(kw.lower() in section_lower for kw in usb_keywords)
                if not is_usb:
                    continue
                
                # Ищем время
                time_match = time_pattern.search(section)
                if not time_match:
                    continue
                
                try:
                    event_time = datetime.datetime.strptime(
                        time_match.group(1), 
                        '%Y/%m/%d %H:%M:%S'
                    )
                except:
                    continue
                
                # Проверяем что событие за последний час
                if event_time < hour_ago:
                    continue
                
                # Определяем тип события
                is_removal = any(kw in section_lower for kw in removal_keywords)
                is_install = any(kw in section_lower for kw in install_keywords)
                
                # Извлекаем имя устройства
                device_name = "USB Device"
                
                # Ищем VID/PID
                vid_match = re.search(r'USB\\VID_([0-9A-F]+)&PID_([0-9A-F]+)', section, re.IGNORECASE)
                if vid_match:
                    device_name = f"USB VID_{vid_match.group(1)} PID_{vid_match.group(2)}"
                
                # Ищем имя в USBSTOR
                stor_match = re.search(r'USBSTOR\\([^\\]+)\\', section, re.IGNORECASE)
                if stor_match:
                    device_name = stor_match.group(1).replace('&', ' ').replace('_', ' ')
                
                # Ищем Disk&Ven
                ven_match = re.search(r'Disk&Ven_([^&]+)&Prod_([^&\\]+)', section, re.IGNORECASE)
                if ven_match:
                    device_name = f"{ven_match.group(1)} {ven_match.group(2)}".strip()
                
                delta = datetime.datetime.now() - event_time
                minutes_ago = int(delta.total_seconds() // 60)
                
                if is_removal:
                    event_type = "USB ИЗВЛЕЧЕНИЕ"
                    severity = "HIGH"
                elif is_install:
                    event_type = "USB ПОДКЛЮЧЕНИЕ"
                    severity = "MEDIUM"
                else:
                    event_type = "USB АКТИВНОСТЬ"
                    severity = "MEDIUM"
                
                events.append({
                    'type': event_type,
                    'name': device_name[:50],
                    'timestamp': event_time.strftime('%Y-%m-%d %H:%M:%S'),
                    'time_ago': f"{minutes_ago} мин. назад",
                    'minutes_ago': minutes_ago,
                    'severity': severity,
                    'source': 'setupapi.dev.log'
                })
                
        except Exception as e:
            self.log(f"   [!] Ошибка чтения setupapi: {str(e)}")
            import traceback
            self.log(f"   [!] {traceback.format_exc()[:200]}")
        
        # Сортируем по времени (свежие первые)
        events.sort(key=lambda x: x.get('minutes_ago', 9999))
        
        return events
    
