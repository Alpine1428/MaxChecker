            self.log(f"   [!] PowerShell error: {str(e)[:50]}")
        
        # Дополнительный сбор через Python (fallback)
        python_twinks = self._collect_twinks_python(minecraft_path)
        twinks.update(python_twinks)
        
        if python_twinks:
            self.log(f"   [+] Python fallback добавил: {len(python_twinks)} твинков")
        
        return twinks, system_info
    
    def _collect_twinks_python(self, minecraft_path: str) -> Set[str]:
        """Дополнительный сбор через Python"""
        twinks = set()
        
        # usercache.json
        usercache_path = os.path.join(minecraft_path, 'usercache.json')
        if os.path.exists(usercache_path):
            try:
                with open(usercache_path, 'r', encoding='utf-8') as f:
                    data = json.load(f)
                    if isinstance(data, list):
                        for item in data:
                            if isinstance(item, dict) and 'name' in item:
                                name = item['name']
                                if 3 <= len(name) <= 16 and re.match(r'^[a-zA-Z0-9_]+$', name):
                                    twinks.add(name)
            except:
                pass
        
        # Логи - setting user:
        logs_path = os.path.join(minecraft_path, 'logs')
        if os.path.exists(logs_path):
            try:
                for file in os.listdir(logs_path):
                    if file.endswith('.log'):
                        file_path = os.path.join(logs_path, file)
                        try:
                            with open(file_path, 'r', encoding='utf-8', errors='ignore') as f:
                                for line in f:
                                    match = re.search(r'setting user:\s*(.+)$', line, re.IGNORECASE)
                                    if match:
                                        name = match.group(1).strip()
                                        if 3 <= len(name) <= 16 and re.match(r'^[a-zA-Z0-9_]+$', name):
                                            twinks.add(name)
                        except:
                            pass
            except:
                pass
        
        return twinks

