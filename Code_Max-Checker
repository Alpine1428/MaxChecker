    def get_critical_findings(self) -> int:
        lm = 0
        if isinstance(self.loaded_modules, dict):
            lm = (len(self.loaded_modules.get('banned_weight', [])) +
                  len(self.loaded_modules.get('suspicious', [])))

        um = 0
        if isinstance(self.unloaded_modules, dict):
            um = (len(self.unloaded_modules.get('banned_weight', [])) +
                  len(self.unloaded_modules.get('deleted', [])))

        jar_critical = len([j for j in self.jar_analysis if j.get('severity') in ['CRITICAL', 'HIGH']])

