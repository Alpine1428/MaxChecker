# MEMORY STRINGS SCANNER (С ОПРЕДЕЛЕНИЕМ ЧИТОВ)
# ═══════════════════════════════════════════════════════════════════

class MemoryStringsScanner:
    def __init__(self, log_callback=None):
        self.log_callback = log_callback or print
        self.compiled_regex = [re.compile(p, re.IGNORECASE) for p in MEMORY_DETECT_REGEX_PATTERNS]
    
    def log(self, msg: str):
        self.log_callback(msg)

    def _extract_string_context(self, data: bytes, idx: int, max_len: int = 200) -> str:
        """Извлекает строку вокруг найденного паттерна"""
        start, end = idx, idx
        while start > 0 and (end - start) < max_len:
            b = data[start - 1]
            if b == 0 or (b < 32 and b not in (9, 10, 13)):
                break
            start -= 1
        n = len(data)
        while end < n and (end - start) < max_len:
            b = data[end]
            if b == 0 or (b < 32 and b not in (9, 10, 13)):
                break
            end += 1
        return data[start:end].decode('utf-8', errors='ignore')

    def _extract_string_utf16(self, data: bytes, idx: int, max_len: int = 400) -> str:
        """Извлекает UTF-16 LE строку"""
        if idx % 2 != 0:
            idx -= 1
        start, end = idx, idx
        n = len(data)
        while start >= 2 and (end - start) < max_len:
            wchar = data[start - 2] | (data[start - 1] << 8)
            if wchar == 0 or (wchar < 32 and wchar not in (9, 10, 13)) or wchar > 127:
                break
            start -= 2
        while end + 2 <= n and (end - start) < max_len:
            wchar = data[end] | (data[end + 1] << 8)
            if wchar == 0 or (wchar < 32 and wchar not in (9, 10, 13)) or wchar > 127:
                break
            end += 2
        try:
            return data[start:end].decode('utf-16-le', errors='ignore')
        except:
            return ""

    def _create_search_variants(self, pattern: bytes) -> List[Tuple[bytes, str]]:
        """Создаёт варианты паттерна для поиска"""
        variants = []
        try:
            text = pattern.decode('utf-8')
            variants.append((text.lower().encode('ascii', errors='ignore'), 'ascii'))
            variants.append((text.upper().encode('ascii', errors='ignore'), 'ascii'))
            variants.append((text.encode('utf-16-le'), 'utf16'))
        except:
            variants.append((pattern, 'ascii'))
        
        seen = set()
        unique = []
        for p, enc in variants:
            if p and p not in seen:
                seen.add(p)
                unique.append((p, enc))
        return unique

    def search_pattern(self, h_process: int, pattern: bytes, max_results: int = 20) -> List[Dict]:
        """Ищет паттерн в памяти процесса"""
        found = []
        mbi = MEMORY_BASIC_INFORMATION()
        max_address = 0x7FFFFFFFFFFF if ctypes.sizeof(ctypes.c_void_p) == 8 else 0x7FFFFFFF
        
        if len(pattern) < 3:
            return found
        
        search_variants = self._create_search_variants(pattern)
        found_results = set()
        address = 0
        regions = 0

        while address < max_address and regions < 5000 and len(found) < max_results:
            if not kernel32.VirtualQueryEx(h_process, ctypes.c_void_p(address), ctypes.byref(mbi), ctypes.sizeof(mbi)):
                break

            can_read = (
                mbi.State == MEM_COMMIT and
                mbi.RegionSize > 0 and
                mbi.RegionSize < 50 * 1024 * 1024 and
                mbi.Protect != 0 and
                not (mbi.Protect & PAGE_NOACCESS) and
                not (mbi.Protect & PAGE_GUARD)
            )

            if can_read:
                try:
                    buf_size = min(mbi.RegionSize, 20 * 1024 * 1024)
                    buffer = ctypes.create_string_buffer(buf_size)
                    bytes_read = ctypes.c_size_t()
                    
                    if kernel32.ReadProcessMemory(h_process, ctypes.c_void_p(mbi.BaseAddress), buffer, len(buffer), ctypes.byref(bytes_read)):
                        data = buffer.raw[:bytes_read.value]
                        
                        for search_pat, encoding in search_variants:
                            if len(found) >= max_results:
                                break
                            
                            idx = data.find(search_pat)
                            if idx != -1:
                                if encoding == 'utf16':
                                    result_str = self._extract_string_utf16(data, idx)
                                else:
                                    result_str = self._extract_string_context(data, idx)
                                
                                result_key = result_str.lower().strip()[:80]
                                
                                if result_key and result_key not in found_results and not is_in_whitelist(result_str):
                                    found_results.add(result_key)
                                    
                                    # Определяем чит по паттерну
                                    cheat_info = get_cheat_info(pattern)
                                    
                                    base = mbi.BaseAddress if mbi.BaseAddress else 0
                                    
                                    found.append({
                                        'pattern': pattern.decode('utf-8', errors='ignore'),
                                        'result': result_str,
                                        'address': hex(base + idx),
                                        'encoding': encoding,
                                        'cheat_name': cheat_info['cheat'] if cheat_info else 'Unknown Pattern',
                                        'cheat_category': cheat_info['category'] if cheat_info else 'unknown',
                                        'action': cheat_info['action'] if cheat_info else 'Требуется проверка',
                                        'found': True
                                    })
                except:
                    pass

            base = mbi.BaseAddress if mbi.BaseAddress else 0
            size = mbi.RegionSize if mbi.RegionSize else 0x1000
            address = base + size
            regions += 1

        return found

    def scan_process_memory(self, pid: int) -> List[Dict]:
        results = []
        self.log(f"   [*] Scanning javaw.exe memory (PID: {pid})...")
        
        try:
            h_process = kernel32.OpenProcess(PROCESS_QUERY_INFORMATION | PROCESS_VM_READ, False, pid)
            if not h_process:
                self.log(f"   [!] Cannot open process {pid}")
                return results

            try:
                total = len(MEMORY_STRING_DETECTS)
                self.log(f"   [*] Searching {total} cheat patterns (ASCII + UTF-16)...")
                
                for i, pattern in enumerate(MEMORY_STRING_DETECTS):
                    matches = self.search_pattern(h_process, pattern)
                    
                    if matches:
                        for m in matches:
                            results.append({
                                'type': 'Memory String',
                                'pattern': m.get('pattern', ''),
                                'result': m.get('result', ''),
                                'pid': pid,
                                'address': m.get('address', 'N/A'),
                                'encoding': m.get('encoding', 'unknown'),
                                'cheat_name': m.get('cheat_name', 'Unknown'),
                                'cheat_category': m.get('cheat_category', 'unknown'),
                                'action': m.get('action', 'Проверить'),
                                'severity': 'CRITICAL',
                            })
                        
                        # Логируем найденный чит
                        cheat = matches[0].get('cheat_name', 'Unknown')
                        pattern_str = pattern.decode('utf-8', errors='ignore')[:40]
                        self.log(f"   [!!!] CHEAT: {cheat}")
                        self.log(f"         Pattern: {pattern_str}")
                        self.log(f"         Action: {matches[0].get('action', 'Проверить')}")
                    
                    if (i + 1) % 10 == 0:
                        self.log(f"   [*] Progress: {i+1}/{total}")
                
                self.log(f"   [+] Pattern scan complete: {len(results)} detects")

                # Regex паттерны
                self.log(f"   [*] Checking {len(self.compiled_regex)} regex patterns...")
                
                address = 0
                mbi = MEMORY_BASIC_INFORMATION()
                regions = 0
                found_regex = set()

                while address < max_address and regions < 3000:
                    if not kernel32.VirtualQueryEx(h_process, ctypes.c_void_p(address), ctypes.byref(mbi), ctypes.sizeof(mbi)):
                        break

                    if (mbi.State == MEM_COMMIT and mbi.RegionSize > 0 and mbi.RegionSize < 30 * 1024 * 1024 and
                        mbi.Protect and not (mbi.Protect & PAGE_NOACCESS) and not (mbi.Protect & PAGE_GUARD)):
                        try:
                            buffer = ctypes.create_string_buffer(min(mbi.RegionSize, 10 * 1024 * 1024))
                            bytes_read = ctypes.c_size_t()
                            
                            if kernel32.ReadProcessMemory(h_process, ctypes.c_void_p(mbi.BaseAddress), buffer, len(buffer), ctypes.byref(bytes_read)):
                                data = buffer.raw[:bytes_read.value]
                                
                                for regex in self.compiled_regex:
                                    for match in regex.findall(data):
                                        match_str = match.decode('utf-8', errors='ignore') if isinstance(match, bytes) else str(match)
                                        if match_str and match_str not in found_regex and not is_in_whitelist(match_str):
                                            found_regex.add(match_str)
                                            base = mbi.BaseAddress if mbi.BaseAddress else 0
                                            
                                            results.append({
                                                'type': 'Memory Regex',
                                                'pattern': regex.pattern.decode(errors='ignore') if isinstance(regex.pattern, bytes) else str(regex.pattern),
                                                'result': match_str,
                                                'pid': pid,
                                                'address': hex(base),
                                                'cheat_name': 'Regex Match',
                                                'action': 'Проверить контекст',
                                                'severity': 'CRITICAL'
                                            })
                                            self.log(f"   [!!!] REGEX: {match_str[:60]}")
                        except:
                            pass

                    base = mbi.BaseAddress if mbi.BaseAddress else 0
                    size = mbi.RegionSize if mbi.RegionSize else 0x1000
                    address = base + size
                    regions += 1

            finally:
                kernel32.CloseHandle(h_process)
                
        except Exception as e:
            self.log(f"   [!] Memory scan error: {str(e)[:80]}")
            
        self.log(f"   [+] Total memory detects: {len(results)}")
        return results

    def scan_all_javaw(self) -> List[Dict]:
        all_results = []
        self.log("   [*] Searching for Minecraft Java processes...")
        
        found_process = False
        for proc in psutil.process_iter(['pid', 'name', 'cmdline']):
            try:
                name = (proc.info['name'] or '').lower()
                cmdline = ' '.join(proc.info.get('cmdline') or []).lower()
                
                if 'java' in name and any(kw in cmdline for kw in ['minecraft', '.minecraft', 'tlauncher', 'lunar', 'badlion', 'labymod', 'feather']):
                    found_process = True
                    self.log(f"   [*] Found Minecraft: {proc.info['name']} (PID: {proc.info['pid']})")
                    all_results.extend(self.scan_process_memory(proc.info['pid']))
            except:
                continue

        if not found_process:
            self.log("   [!] No Minecraft Java process found!")

        if all_results:
            self.log(f"\n   [+] ══════ CHEAT DETECTION SUMMARY ══════")
            cheats_found = {}
            for r in all_results:
                cheat = r.get('cheat_name', 'Unknown')
                if cheat not in cheats_found:
                    cheats_found[cheat] = {'count': 0, 'action': r.get('action', '')}
                cheats_found[cheat]['count'] += 1
            
            for cheat, info in cheats_found.items():
                self.log(f"   [{info['count']}x] {cheat}")
                self.log(f"        → {info['action']}")

        return all_results
		
