        return events
    
    def check_flash_drive_usage(self) -> List[Dict]:
        """
        ГЛАВНЫЙ МЕТОД - комбинирует ВСЕ методы для 100% обнаружения USB.
        """
        all_events = []
        
        self.log(f"   [*] ═══════════════════════════════════════════════════")
        self.log(f"   [*] USB СКАНИРОВАНИЕ (последние {USB_SCAN_PERIOD_MINUTES} мин)")
