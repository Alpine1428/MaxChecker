def ensure_single_instance() -> bool:
    """
    Разрешаем только один экземпляр программы во всей системе.
    Используем именованный мьютекс через WinAPI CreateMutexW.
    """
    try:
        mutex_name = "HolyWorldChecker_SingleInstance_Mutex"
        kernel32 = ctypes.windll.kernel32
        handle = kernel32.CreateMutexW(None, False, mutex_name)
        if not handle:
            return True  # не смогли создать мьютекс — не блокируем запуск

        ERROR_ALREADY_EXISTS = 183
        last_err = kernel32.GetLastError()
        if last_err == ERROR_ALREADY_EXISTS:
            return False
        return True
    except:
        return True  # при ошибке не блокируем запуск


