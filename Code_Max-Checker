    def get_usb_from_registry_timestamps(self) -> List[Dict]:
        """Читает временные метки из реестра USB устройств"""
        events = []
        hour_ago = datetime.datetime.now() - datetime.timedelta(minutes=USB_SCAN_PERIOD_MINUTES)
        
        if not WINREG_AVAILABLE:
            return events
        
        # Проверяем несколько мест в реестре
        registry_paths = [
            (r"SYSTEM\CurrentControlSet\Enum\USBSTOR", "USBSTOR"),
            (r"SYSTEM\CurrentControlSet\Enum\USB", "USB"),
        ]
        
        for reg_path, source in registry_paths:
            try:
                with winreg.OpenKey(winreg.HKEY_LOCAL_MACHINE, reg_path, 0,
                                   winreg.KEY_READ | winreg.KEY_WOW64_64KEY) as main_key:
                    
                    for i in range(winreg.QueryInfoKey(main_key)[0]):
                        try:
                            subkey_name = winreg.EnumKey(main_key, i)
                            
                            # Для USBSTOR ищем устройства
                            if source == "USBSTOR" or subkey_name.startswith("VID_"):
                                with winreg.OpenKey(main_key, subkey_name, 0,
                                                   winreg.KEY_READ | winreg.KEY_WOW64_64KEY) as sub_key:
                                    
                                    for j in range(winreg.QueryInfoKey(sub_key)[0]):
                                        try:
                                            instance_name = winreg.EnumKey(sub_key, j)
                                            
                                            with winreg.OpenKey(sub_key, instance_name, 0,
                                                               winreg.KEY_READ | winreg.KEY_WOW64_64KEY) as dev_key:
                                                
                                                # Получаем время последней записи
                                                key_info = winreg.QueryInfoKey(dev_key)
                                                last_write_time = key_info[2]  # FILETIME
                                                
                                                if last_write_time > 0:
                                                    # Конвертируем FILETIME в datetime
                                                    EPOCH_DIFF = 116444736000000000
                                                    timestamp = (last_write_time - EPOCH_DIFF) / 10000000
                                                    
                                                    if timestamp > 0:
                                                        event_time = datetime.datetime.fromtimestamp(timestamp)
                                                        
                                                        if event_time > hour_ago:
                                                            # Получаем имя устройства
                                                            device_name = subkey_name
                                                            try:
                                                                device_name = winreg.QueryValueEx(dev_key, "FriendlyName")[0]
                                                            except:
                                                                try:
                                                                    desc = winreg.QueryValueEx(dev_key, "DeviceDesc")[0]
                                                                    if ';' in desc:
                                                                        device_name = desc.split(';')[-1]
                                                                except:
                                                                    pass
                                                            
                                                            delta = datetime.datetime.now() - event_time
                                                            minutes_ago = int(delta.total_seconds() // 60)
                                                            
                                                            events.append({
                                                                'type': 'USB АКТИВНОСТЬ (Registry)',
                                                                'name': device_name[:50],
                                                                'timestamp': event_time.strftime('%Y-%m-%d %H:%M:%S'),
                                                                'time_ago': f"{minutes_ago} мин. назад",
                                                                'minutes_ago': minutes_ago,
                                                                'severity': 'MEDIUM',
                                                                'source': f'Registry:{source}'
                                                            })
                                        except:
                                            continue
                        except:
                            continue
            except:
                continue
        
        return events
    
    def get_usb_from_powershell(self) -> List[Dict]:
        """Получает USB события через PowerShell (PnP события)"""
        events = []
        hour_ago = datetime.datetime.now() - datetime.timedelta(minutes=USB_SCAN_PERIOD_MINUTES)
        
        # Простой и надёжный PowerShell скрипт
        ps_script = f'''
$ErrorActionPreference = 'SilentlyContinue'
$startTime = (Get-Date).AddMinutes(-{USB_SCAN_PERIOD_MINUTES})

# Метод 1: PnP события
$pnpEvents = Get-WinEvent -LogName System -MaxEvents 5000 | Where-Object {{
    $_.TimeCreated -gt $startTime -and
    $_.ProviderName -match 'Microsoft-Windows-Kernel-PnP|PlugPlay' -and
    $_.Message -match 'USB|USBSTOR|Disk|Storage'
}} | Select-Object -First 30

foreach ($e in $pnpEvents) {{
    $type = "USB_EVENT"
    $msg = $e.Message
    if ($msg -match 'removed|eject|unplugged') {{ $type = "REMOVE" }}
    elseif ($msg -match 'configured|installed|plugged|started') {{ $type = "CONNECT" }}
    
    Write-Output "PNPEVENT|$($e.TimeCreated.ToString('yyyy-MM-dd HH:mm:ss'))|$type|$($e.Id)"
}}

# Метод 2: Текущие USB диски
Get-WmiObject Win32_DiskDrive | Where-Object {{ $_.InterfaceType -eq 'USB' }} | ForEach-Object {{
    Write-Output "CONNECTED|$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')|$($_.Caption)|$([math]::Round($_.Size/1GB, 2))GB"
}}

# Метод 3: События установки устройств
Get-WinEvent -LogName "Microsoft-Windows-DeviceSetupManager/Admin" -MaxEvents 100 | Where-Object {{
    $_.TimeCreated -gt $startTime -and
    $_.Message -match 'USB|USBSTOR|Disk'
}} | Select-Object -First 10 | ForEach-Object {{
    Write-Output "SETUPEVENT|$($_.TimeCreated.ToString('yyyy-MM-dd HH:mm:ss'))|DEVICE_SETUP|$($_.Id)"
}}
'''
        
        try:
            result = subprocess.run(
                ['powershell', '-NoProfile', '-NonInteractive', '-ExecutionPolicy', 'Bypass',
                 '-WindowStyle', 'Hidden', '-Command', ps_script],
                capture_output=True, text=True, timeout=60,
                creationflags=subprocess.CREATE_NO_WINDOW
            )
            
            for line in result.stdout.strip().split('\n'):
                line = line.strip()
                if not line or '|' not in line:
                    continue
                
                parts = line.split('|')
                
                if parts[0] == 'PNPEVENT' and len(parts) >= 4:
                    try:
                        event_time = datetime.datetime.strptime(parts[1], '%Y-%m-%d %H:%M:%S')
                        delta = datetime.datetime.now() - event_time
                        minutes_ago = int(delta.total_seconds() // 60)
                        
                        event_type = "USB ИЗВЛЕЧЕНИЕ (PnP)" if parts[2] == "REMOVE" else \
                                    "USB ПОДКЛЮЧЕНИЕ (PnP)" if parts[2] == "CONNECT" else \
                                    "USB EVENT (PnP)"
                        
                        events.append({
                            'type': event_type,
                            'name': f"Event ID: {parts[3]}",
                            'timestamp': parts[1],
                            'time_ago': f"{minutes_ago} мин. назад",
                            'minutes_ago': minutes_ago,
                            'severity': 'HIGH' if 'ИЗВЛЕЧЕНИЕ' in event_type else 'MEDIUM',
                            'source': 'PowerShell:PnP'
                        })
                    except:
                        pass
                
                elif parts[0] == 'CONNECTED' and len(parts) >= 4:
                    events.append({
                        'type': 'USB ПОДКЛЮЧЁН СЕЙЧАС',
                        'name': f"{parts[2]} ({parts[3]})",
                        'timestamp': parts[1],
                        'time_ago': 'подключён сейчас',
                        'minutes_ago': 0,
                        'severity': 'INFO',
                        'source': 'PowerShell:WMI'
                    })
                
                elif parts[0] == 'SETUPEVENT' and len(parts) >= 4:
                    try:
                        event_time = datetime.datetime.strptime(parts[1], '%Y-%m-%d %H:%M:%S')
                        delta = datetime.datetime.now() - event_time
                        minutes_ago = int(delta.total_seconds() // 60)
                        
                        events.append({
