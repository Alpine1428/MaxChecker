class HolyChecker:
    def __init__(self, minecraft_path: str, log_callback=None):
        self.minecraft_path = minecraft_path
        self.result = CheckResult()
        self.log_callback = log_callback or print

    def log(self, msg: str):
        self.log_callback(msg)

    def run_all_checks(self):
        self.log("🔧 Инициализация сканирования...")
        tasks = []

        def t_gpu_info():
            self.result.gpu_info = get_gpu_info()
        tasks.append(("🎮 GPU Info", t_gpu_info))

        def t_vm_detection():
            vm_detected, vm_status, vm_details = VMDetector(self.log).run_all_checks()
            self.result.vm_detected = vm_detected
            self.result.vm_status = vm_status
            self.result.vm_details = vm_details
            if vm_detected:
                self.result.add_ban("VM", "Virtual Machine", "; ".join(vm_details[:3]))
        tasks.append(("🖥️ VM Detection", t_vm_detection))

        def t_services():
            ServicesManager(self.log).check_and_start_services()
        tasks.append(("⚙️ Services", t_services))

        def t_site_blocking():
            self.result.site_blocking = SiteBlockingChecker(self.log).check_sites()
            for s in self.result.site_blocking:
                self.result.add_ban("Site Block", s['site'], s['methods'])
        tasks.append(("🚫 Site Blocking", t_site_blocking))

        def t_cheat_sites():
            self.result.cheat_sites = CheatSitesChecker(self.log).check_all()
        tasks.append(("🌐 Cheat Sites Check", t_cheat_sites))

        def t_network_bypass():
            self.result.network_bypass = NetworkBypassDetector(self.log).check_javaw_connections()
            for n in self.result.network_bypass:
                self.result.add_ban("Network", f"Bypass: {n['remote_ip']}", "192.168.x.x connection")
        tasks.append(("🌐 Network Bypass", t_network_bypass))

        def t_process_analysis():
            analysis = ProcessAnalyzer(self.log).analyze_javaw()
            self.result.process_analysis = analysis
            if analysis.get('banned_dll'):
                for mod in analysis['banned_dll']:
                    self.result.add_ban("DLL", mod['reason'], mod['path'][:60])
        tasks.append(("🔬 Process Analysis", t_process_analysis))

        def t_loaded_modules():
            self.result.loaded_modules = LoadedModulesScanner(self.log).scan_javaw_modules()
        tasks.append(("📦 Loaded Modules", t_loaded_modules))

        def t_unloaded_modules():
            self.result.unloaded_modules = UnloadedModulesScanner(self.log).scan_javaw_unloaded()
        tasks.append(("💉 Unloaded Modules Scan", t_unloaded_modules))

        def t_memory_strings():
            self.result.memory_strings = MemoryStringsScanner(self.log).scan_all_javaw()
            for item in self.result.memory_strings:
                if item.get('should_ban', True):
                    self.result.add_ban("Memory", f"Detect: {item.get('cheat_name', 'Unknown')[:30]}", item.get('pattern', '')[:30])
        tasks.append(("🧠 Memory Strings Scan", t_memory_strings))

        def t_dps():
            self.result.dps_results = DPSServiceScanner(self.log).scan_dps_memory()
        tasks.append(("📋 DPS Service Scan", t_dps))

        def t_csrss():
            self.result.csrss_paths = CsrssPathsParser(self.log).analyze_paths()
            for item in self.result.csrss_paths:
                if item.get('banned_size'):
                    self.result.add_ban("CSRSS", item['banned_size'], item['path'][:50])
        tasks.append(("🔍 CSRSS Paths Parse", t_csrss))

        def t_jar_mods():
            self.result.jar_analysis = JarModAnalyzer(self.log).scan_mods_folder(self.minecraft_path)
            for item in self.result.jar_analysis:
                if item.get('severity') in ['CRITICAL', 'HIGH']:
                    self.result.add_ban("Mod", f"Suspicious: {item.get('name', '')}", ', '.join(item.get('cheat_classes', [])[:3]))
        tasks.append(("📦 JAR Mod Analysis", t_jar_mods))

        def t_jumplists():
            self.result.jumplist_results = JumpListAnalyzer(self.log).analyze_jumplists()
            for item in self.result.jumplist_results:
                if item['severity'] == 'CRITICAL':
                    self.result.add_ban("JumpList", item['filename'], 'DELETED' if not item.get('exists') else 'EXISTS')
        tasks.append(("📑 JumpList Analysis", t_jumplists))

        def t_registry_cleaning():
            self.result.registry_cleaning = RegistryCleaningDetector(self.log).check_all()
            for item in self.result.registry_cleaning:
                if item['severity'] == 'CRITICAL':
                    self.result.add_ban("Registry", f"Cleaning: {item['key']}", item['type'])
        tasks.append(("🧹 Registry Cleaning Check", t_registry_cleaning))

        def t_prefetch_usb():
            self.result.prefetch_usb = PrefetchUSBAnalyzer(self.log).check_usb_launches()
            for item in self.result.prefetch_usb:
                if item['severity'] == 'CRITICAL':
                    self.result.add_ban("USB", f"Launch: {item['exe_name']}", "")
        tasks.append(("💾 Prefetch USB Check", t_prefetch_usb))

        def t_bam():
            bam_analyzer = BAMAnalyzer(self.log)
            self.result.bam_results = bam_analyzer.check_bam()
            self.result.bam_unsigned = bam_analyzer.check_bam_unsigned()
            for item in self.result.bam_unsigned:
                if item['severity'] == 'CRITICAL':
                    self.result.add_ban("BAM", f"Deleted: {item['filename']}", item['path'][:50])
        tasks.append(("📝 BAM Check", t_bam))

        def t_deleted():
            detector = DeletedFilesDetector(self.log)
            self.result.deleted_files = detector.scan_all(self.minecraft_path)
            _, clear_info = detector.get_last_recycle_bin_clear_time()
            self.result.last_recycle_clear = clear_info
            for item in self.result.deleted_files:
                if item.get('severity') == 'CRITICAL':
                    self.result.add_ban("Deleted", item['filename'][:40], item.get('type', ''))
        tasks.append(("🗑️ Deleted Files Detection", t_deleted))

        # ═══════════════════════════════════════════════════════════════
        # USB ACTIVITY - ИСПРАВЛЕННЫЙ
        # ═══════════════════════════════════════════════════════════════
        def t_usb_activity():
            self.log("   [*] Запуск USB сканера...")
            try:
                usb_detector = USBFlashDetector(self.log)
                usb_results = usb_detector.check_flash_drive_usage()
                self.result.usb_activity = usb_results
                
                # Ищем последнее извлечение/активность
                last_removal_str = "Не определено"
                
                for item in usb_results:
                    item_type = str(item.get('type', '')).upper()
                    
                    # Ищем извлечения или активность
                    if any(kw in item_type for kw in ['ИЗВЛЕЧЕНИЕ', 'АКТИВНОСТЬ', 'REMOVAL', 'REMOVE']):
                        timestamp = item.get('timestamp', '')
                        time_ago = item.get('time_ago', '')
                        name = item.get('name', 'USB Device')[:35]
                        
                        if timestamp:
                            last_removal_str = f"{timestamp} ({time_ago}) - {name}"
                            break
                
                # Проверяем summary если нет активности
                if last_removal_str == "Не определено":
                    for item in usb_results:
                        if item.get('type') == 'USB SUMMARY':
                            total = item.get('removals_count', 0) + item.get('arrivals_count', 0)
                            if total == 0:
                                last_removal_str = "Нет USB активности за последний час"
                            break
                
                self.result.last_usb_disconnect = last_removal_str
                self.log(f"   [+] USB: {len(usb_results)} записей")
                self.log(f"   [+] Last USB: {last_removal_str[:60]}")
                
            except Exception as e:
                import traceback
                self.log(f"   [!] USB ошибка: {str(e)}")
                self.log(f"   [!] {traceback.format_exc()[:150]}")
                self.result.usb_activity = []
                self.result.last_usb_disconnect = f"Ошибка сканирования"
        
        tasks.append(("💿 USB Activity", t_usb_activity))

        def t_file_search():
            self.result.found_files = FileSearcher(self.log).quick_search(self.minecraft_path)
            for fp, reason, _, _ in self.result.found_files:
                self.result.add_ban("File", reason, os.path.basename(fp))
        tasks.append(("📁 File Search", t_file_search))

        def t_blocked_access():
            self.result.blocked_access = BlockedAccessChecker(self.log).check_all()
            for item in self.result.blocked_access:
                self.result.add_ban("Block", f"Blocked: {item.get('match')}", "")
        tasks.append(("🚫 Blocked Access Check", t_blocked_access))

        def t_prefetch():
            self.result.prefetch_results = PrefetchAnalyzer(self.log).check_prefetch()
        tasks.append(("⭐ Prefetch Check", t_prefetch))

        def t_discord():
            self.result.discord_results = DiscordChecker(self.log).check_discord()
        tasks.append(("💬 Discord Check", t_discord))

        def t_crash():
            self.result.crash_results = CrashReportAnalyzer(self.log).check_crashes(self.minecraft_path)
        tasks.append(("💥 Crash Reports Check", t_crash))

        def t_twinks():
            twinks, sys_info = TwinksCollector(self.log).collect_twinks(self.minecraft_path)
            for t in twinks:
                self.result.add_twink(t)
            self.result.system_info = sys_info
        tasks.append(("👤 Twinks Collection", t_twinks))

        def t_logs():
            self.result.logs_content, self.result.logs_count = LogArchiver(self.minecraft_path, self.log).process_logs_to_memory()
        tasks.append(("📜 Logs Archive", t_logs))

        # Выполнение задач
        total_tasks = len(tasks)
        completed = 0
        lock = threading.Lock()
        threads = []

        def worker(name: str, func):
            nonlocal completed
            try:
                self.log(f"[*] {name}...")
                func()
            except Exception as e:
                self.log(f"[!] {name} error: {str(e)[:80]}")
            finally:
                with lock:
                    completed += 1
                    self.log(f"[{completed}/{total_tasks}] {name}")

        for name, func in tasks:
            t = threading.Thread(target=worker, args=(name, func), daemon=True)
            threads.append(t)
            t.start()

        for t in threads:
            t.join()

        self.log(f"✅ Complete! Found: {self.result.get_total_findings()} violations")
        return self.result
