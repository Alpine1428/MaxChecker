            r.append("  ╚══════════════════════════════════════════════════════════════════╝")
            r.append("")
            for item in self.crash_results:
                r.append(f"    ⚠️ {item.get('file', 'Unknown')[:40]} — match: {item.get('match', '')}")
            r.append("")

        # ═══════════════════════════════════════════════════
        # 📁 FOUND FILES
        # ═══════════════════════════════════════════════════
        if self.found_files:
            r.append("  ╔══════════════════════════════════════════════════════════════════╗")
            r.append(f"  ║                    📁 НАЙДЕННЫЕ ФАЙЛЫ ({len(self.found_files)})                        ║")
            r.append("  ╚══════════════════════════════════════════════════════════════════╝")
            r.append("")
            for fp, reason, size, date in self.found_files[:20]:
                filename = os.path.basename(fp)
                size_mb = round(size / 1024 / 1024, 2) if size > 0 else 0
                date_str = date.strftime('%Y-%m-%d %H:%M') if date else 'Unknown'
                r.append(f"    🚨 {filename[:40]} ({size_mb} MB) — {date_str}")
                r.append(f"       Reason: {reason}")
                r.append(f"       Path: {fp[:60]}")
            r.append("")
            r.append("    ℹ️ Бан если дата модификации/открытия < 14 дней.")
            r.append("")

        # ═══════════════════════════════════════════════════
        # 🚫 BLOCKED ACCESS (hosts)
        # ═══════════════════════════════════════════════════
        if self.blocked_access:
            r.append("  ╔══════════════════════════════════════════════════════════════════╗")
            r.append(f"  ║               🚫 BLOCKED ACCESS ({len(self.blocked_access)})                           ║")
            r.append("  ╚══════════════════════════════════════════════════════════════════╝")
            r.append("")
            for item in self.blocked_access:
                r.append(f"    🚨 Line {item.get('line', '?')}: {item.get('match', 'Unknown')}")
            r.append("")

        # ═══════════════════════════════════════════════════
        # 👤 TWINKS
        # ═══════════════════════════════════════════════════
        if self.twinks:
            r.append("  ╔══════════════════════════════════════════════════════════════════╗")
            r.append(f"  ║                  👤 ТВИНКИ ИГРОКА ({len(self.twinks)})                            ║")
            r.append("  ╚══════════════════════════════════════════════════════════════════╝")
            r.append("")
            sorted_twinks = sorted(self.twinks)
            for i in range(0, len(sorted_twinks), 5):
                chunk = sorted_twinks[i:i + 5]
                r.append(f"    {' | '.join(chunk)}")
            r.append("")

        # ═══════════════════════════════════════════════════
        # 📜 LOGS INFO
        # ═══════════════════════════════════════════════════
        if self.logs_count > 0:
            r.append("  ╔══════════════════════════════════════════════════════════════════╗")
            r.append(f"  ║                     📜 ЛОГИ                                      ║")
            r.append("  ╚══════════════════════════════════════════════════════════════════╝")
            r.append("")
            logs_size_kb = round(len(self.logs_content) / 1024, 1) if self.logs_content else 0
            r.append(f"    • Файлов логов собрано: {self.logs_count}")
            r.append(f"    • Размер архива: {logs_size_kb} KB")
            r.append("")

        # ═══════════════════════════════════════════════════
        # ЗАВЕРШЕНИЕ
        # ═══════════════════════════════════════════════════
        r.append(self._format_separator("═"))
        r.append(self._center_text("╔═══════════════════════════════════════════╗"))
        r.append(self._center_text("║          🏁 СКАНИРОВАНИЕ ЗАВЕРШЕНО        ║"))
        r.append(self._center_text("╚═══════════════════════════════════════════╝"))
        r.append(self._format_separator("═"))
        r.append("")

        jar_suspicious = len([j for j in self.jar_analysis if j.get('severity') in ['CRITICAL', 'HIGH']])
        debugger_count = len(self.system_info.get('debugger_restrictions', []))
        packed_count = len(self.system_info.get('packed_dlls', []))
        event_clear_count = len(self.system_info.get('event_log_clearing', []))

        r.append(f"  📊 Итого:")
        r.append(f"     • Критических нарушений: {self.get_critical_findings()}")
        r.append(f"     • Посещений сайтов читов: {len(self.cheat_sites)}")
        r.append(f"     • Подозрительных модов: {jar_suspicious}")
        r.append(f"     • Твинков найдено: {len(self.twinks)}")
        r.append(f"     • Файлов логов: {self.logs_count}")

        if debugger_count > 0:
            r.append(f"     • Дебаггеры/IFEO: {debugger_count}")
        if packed_count > 0:
            r.append(f"     • Упакованные DLL: {packed_count}")
        if event_clear_count > 0:
            r.append(f"     • Очистка журналов: {event_clear_count}")

        r.append("")

        if self.should_ban():
            r.append("  ⚠️ РЕКОМЕНДАЦИЯ: ТРЕБУЕТСЯ ПРОВЕРКА МОДЕРАТОРОМ")
        else:
            r.append("  ✅ Критических нарушений не обнаружено")

        r.append("")
        r.append(self._format_separator("═"))
        r.append(self._center_text("END OF REPORT"))
        r.append(self._format_separator("═"))

        return "\n".join(r)
