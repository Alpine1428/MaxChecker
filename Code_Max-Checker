class VMDetector:
    def __init__(self, log_callback=None):
        self.log_callback = log_callback or print
    
    def log(self, msg: str): self.log_callback(msg)
    
    def check_mac_address(self) -> Tuple[bool, str, str]:
        """Проверка MAC адреса на принадлежность к VM"""
        try:
            for iface, addrs in psutil.net_if_addrs().items():
                for addr in addrs:
                    if addr.family == psutil.AF_LINK:
                        mac = addr.address.upper().replace("-", ":")
                        mac_prefix = mac[:8]
                        
                        for prefix, vm_type in VM_MAC_DATABASE.items():
                            if mac.startswith(prefix.upper()):
                                self.log(f"   [!!!] VM MAC: {mac} -> {vm_type}")
                                return True, mac, vm_type
        except Exception as e:
            self.log(f"   [!] MAC check error: {e}")
        return False, "", ""
    
    def run_all_checks(self) -> Tuple[bool, str, List[str]]:
        detections = []
        vm_type_detected = None
        
        # Проверка MAC адреса
        mac_detected, mac_addr, mac_vm_type = self.check_mac_address()
        if mac_detected:
            detections.append(f"MAC Address: {mac_addr} -> {mac_vm_type}")
            vm_type_detected = mac_vm_type
        
        # Проверка процессов
        for proc in psutil.process_iter(['name']):
            try:
                if proc.info['name'].lower() in [p.lower() for p in VM_PROCESSES]: 
                    detections.append(f"Process: {proc.info['name']}")
            except: pass
        
        # Проверка реестра
        if WINREG_AVAILABLE:
            for key_path, vm_type in VM_REGISTRY_KEYS:
                try:
                    with winreg.OpenKey(winreg.HKEY_LOCAL_MACHINE, key_path): 
                        detections.append(f"Registry: {vm_type}")
                        if not vm_type_detected:
                            vm_type_detected = vm_type
                except: pass
        
        # Проверка BIOS
        if WMI_AVAILABLE:
            try:
                c = wmi.WMI()
                for bios in c.Win32_BIOS():
                    bios_str = f"{bios.Manufacturer} {bios.SMBIOSBIOSVersion}".lower()
                    for vm_string in VM_BIOS_STRINGS:
                        if vm_string in bios_str: 
                            detections.append(f"BIOS: {vm_string}")
            except: pass
        
        if detections:
            status = f"⚠️ Обнаружена VM"
            if vm_type_detected:
                status += f" ({vm_type_detected})"
            if mac_detected:
                status += f"\nMAC: {mac_addr}"
            return True, status, detections
        
        return False, "✅ Real PC", []

