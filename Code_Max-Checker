        self.log(f"   [*] → Найдено: {len(setupapi_events)} событий")
        
        # МЕТОД 2: Реестр
        self.log("   [*] Метод 2: Реестр Windows...")
        registry_events = self.get_usb_from_registry_timestamps()
        all_events.extend(registry_events)
        self.log(f"   [*] → Найдено: {len(registry_events)} событий")
        
        # МЕТОД 3: PowerShell (PnP + WMI)
        self.log("   [*] Метод 3: PowerShell (PnP/WMI)...")
        ps_events = self.get_usb_from_powershell()
        all_events.extend(ps_events)
        self.log(f"   [*] → Найдено: {len(ps_events)} событий")
        
        # МЕТОД 4: Текущие USB диски (WMI напрямую)
        self.log("   [*] Метод 4: WMI текущие диски...")
        current_drives = self.get_current_usb_drives()
        all_events.extend(current_drives)
        self.log(f"   [*] → Найдено: {len(current_drives)} дисков")
        
        # Удаляем дубликаты по времени
        seen = set()
        unique_events = []
        for event in all_events:
            key = f"{event.get('timestamp', '')}_{event.get('type', '')}"
            if key not in seen:
                seen.add(key)
                unique_events.append(event)
        
        # Сортируем по времени
        unique_events.sort(key=lambda x: x.get('minutes_ago', 9999))
        
        # Подсчитываем статистику
        removals = [e for e in unique_events if 'ИЗВЛЕЧЕНИЕ' in e.get('type', '').upper() or 'REMOVE' in e.get('type', '').upper()]
        connections = [e for e in unique_events if 'ПОДКЛЮЧЕНИЕ' in e.get('type', '').upper() or 'CONNECT' in e.get('type', '').upper()]
        connected_now = [e for e in unique_events if 'СЕЙЧАС' in e.get('type', '').upper()]
        
        # Добавляем SUMMARY
        unique_events.append({
            'type': 'USB SUMMARY',
            'removals_count': len(removals),
            'arrivals_count': len(connections),
            'connected_now': len(connected_now),
            'total_events': len(unique_events),
            'severity': 'INFO'
        })
        
        # Выводим результаты
        self.log(f"   [*] ───────────────────────────────────────────────────")
        self.log(f"   [*] РЕЗУЛЬТАТЫ USB:")
        self.log(f"   [*]   Всего событий: {len(unique_events) - 1}")
        self.log(f"   [*]   Извлечений: {len(removals)}")
        self.log(f"   [*]   Подключений: {len(connections)}")
        self.log(f"   [*]   Подключено сейчас: {len(connected_now)}")
        
        if removals:
            self.log(f"   [!!!] ══════════════════════════════════════════════")
