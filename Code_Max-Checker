# EVENT LOG CLEARING DETECTOR (расширенный)
# Проверяет события очистки журналов + AppCompat
# ═══════════════════════════════════════════════════════════════════

class EventLogClearingDetector:
    """
    Проверяет:
    - Event ID 104 (System) — очистка журналов
    - Event ID 1102 (Security) — очистка журнала безопасности
    - Event ID 3079 (Application) — изменения тома удалены
    """

    def __init__(self, log_callback=None):
        self.log_callback = log_callback or print

    def log(self, msg: str):
        self.log_callback(msg)

    def check_event_log_clearing(self) -> List[Dict]:
        results = []

        ps_script = r'''
$ErrorActionPreference = 'SilentlyContinue'

# Event ID 104 — System log cleared
Get-WinEvent -LogName System -FilterXPath "*[System[(EventID=104)]]" -MaxEvents 30 | ForEach-Object {
    $desc = ($_.Message -split "`n")[0].Trim()
    Write-Output "EVENT|104|$($_.TimeCreated.ToString('yyyy-MM-dd HH:mm:ss'))|$desc"
}

# Event ID 1102 — Security log cleared
Get-WinEvent -LogName Security -FilterXPath "*[System[(EventID=1102)]]" -MaxEvents 30 | ForEach-Object {
    $desc = ($_.Message -split "`n")[0].Trim()
    Write-Output "EVENT|1102|$($_.TimeCreated.ToString('yyyy-MM-dd HH:mm:ss'))|$desc"
}

# Event ID 3079 — Application (USN journal deleted)
Get-WinEvent -LogName Application -FilterXPath "*[System[(EventID=3079)]]" -MaxEvents 10 | ForEach-Object {
    $desc = ($_.Message -split "`n")[0].Trim()
    Write-Output "EVENT|3079|$($_.TimeCreated.ToString('yyyy-MM-dd HH:mm:ss'))|$desc"
}
'''

        try:
            result = run_powershell_hidden(ps_script, 60)

            for line in result.stdout.strip().split('\n'):
                line = line.strip()
                if not line.startswith('EVENT|'):
                    continue

                parts = line.split('|')
                if len(parts) < 4:
                    continue

                event_id = parts[1]
                timestamp = parts[2]
                description = '|'.join(parts[3:])[:100]

                severity = 'CRITICAL' if event_id in ['104', '1102'] else 'HIGH'

                results.append({
                    'type': f'Event Log Clear (ID {event_id})',
                    'event_id': event_id,
                    'timestamp': timestamp,
                    'description': description,
                    'severity': severity,
                })

                self.log(f"   [!!!] EVENT {event_id}: {timestamp} — {description[:50]}")

        except Exception as e:
            self.log(f"   [!] Event log check error: {str(e)[:50]}")

        return results


